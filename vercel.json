{
  "crons": [
    {
      "path": "/api/cron/refresh-odds",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/trends",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/trends",
      "schedule": "0 17 * * *"
    },
    { "path": "/api/cron/grade-picks", "schedule": "*/5 15-23 * * *" },
    { "path": "/api/cron/grade-picks", "schedule": "*/5 0-9 * * *" },
    { "path": "/api/cron/grade-picks", "schedule": "*/5 10-14 * * *" },
    { "path": "/api/cron/pregenerate-analysis?sport=mlb",  "schedule": "0 12 * * *" },
    { "path": "/api/cron/pregenerate-analysis?sport=nba",  "schedule": "6 12 * * *" },
    { "path": "/api/cron/pregenerate-analysis?sport=nhl",  "schedule": "12 12 * * *" },
    { "path": "/api/cron/pregenerate-analysis?sport=nfl",  "schedule": "18 12 * * *" },
    { "path": "/api/cron/pregenerate-analysis?sport=mls",  "schedule": "24 12 * * *" },
    { "path": "/api/cron/pregenerate-analysis",            "schedule": "0 14 * * *" },
    { "path": "/api/cron/pregenerate-analysis",            "schedule": "0 16 * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "goatbot-tracker.vercel.app" }],
      "destination": "https://betos.win/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "goatbot-tracker-lead-forgev1.vercel.app" }],
      "destination": "https://betos.win/$1",
      "permanent": true
    }
  ]
}
