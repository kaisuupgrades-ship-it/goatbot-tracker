{
  "crons": [
    {
      "path": "/api/cron/refresh-odds",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/trends",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/trends",
      "schedule": "0 17 * * *"
    },
    { "path": "/api/cron/grade-picks", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/grade-check",                     "schedule": "0 */2 * * *" },
    { "path": "/api/cron/refresh-enrichment",              "schedule": "*/5 * * * *" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "goatbot-tracker.vercel.app" }],
      "destination": "https://betos.win/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "goatbot-tracker-lead-forgev1.vercel.app" }],
      "destination": "https://betos.win/$1",
      "permanent": true
    }
  ]
}
