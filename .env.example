# Supabase (get these from https://supabase.com → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# xAI Grok API (get from https://console.x.ai)
XAI_API_KEY=xai-your-key-here

# Anthropic Claude API — fallback AI when xAI is unavailable (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Odds APIs
THE_ODDS_API_KEY=your-the-odds-api-key-here   # primary — get from https://the-odds-api.com
ODDS_API_KEY=your-odds-api-key-here            # legacy fallback — get from https://odds-api.io

# Cron job security — all /api/cron/* routes require this as a Bearer token
# Set a long random string, e.g.: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Admin access — comma-separated list of admin email addresses
# e.g.: admin@example.com,backup-admin@example.com
ADMIN_EMAILS=your-admin-email@example.com

# Canonical site URL — used for OAuth redirects and absolute URL construction
NEXT_PUBLIC_SITE_URL=https://betos.win
